{
    "name": "@workspace/api-server",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "set \"NODE_ENV=development\" && set \"PORT=8787\" && pnpm run build && pnpm run start",
        "build": "node ./build.mjs",
        "start": "node --enable-source-maps ./dist/index.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@workspace/api-zod": "workspace:*",
        "@workspace/db": "workspace:*",
        "better-sqlite3": "^11.10.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2",
        "drizzle-orm": "catalog:",
        "express": "^5",
        "form-data": "^4.0.5",
        "multer": "^2.1.1",
        "node-fetch": "^3.3.2",
        "pino": "^9",
        "pino-http": "^10"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "catalog:",
        "@types/node-fetch": "^2.6.13",
        "esbuild": "^0.27.3",
        "esbuild-plugin-pino": "^2.3.3",
        "pino-pretty": "^13",
        "thread-stream": "3.1.0"
    }
}
